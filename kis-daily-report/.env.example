# ===== OpenRouter API (LLM) =====
# https://openrouter.ai 에서 발급받은 API 키
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ===== 한국투자증권 (KIS) API =====
# KIS 개발자 센터(https://apiportal.koreainvestment.com)에서 발급받은 앱 키/시크릿
KIS_APP_KEY=your_kis_app_key_here
KIS_APP_SECRET=your_kis_app_secret_here

# 실전투자 계좌번호 (하이픈 포함 형식: XXXXXXXX-XX)
# 예시: 68222717-01
KIS_ACCOUNT=68222717-01

# ===== 네이버 검색 API =====
# https://developers.naver.com 에서 애플리케이션 등록 후 발급
# 사용 API: 검색 > 뉴스 검색 (하루 25,000건 무료)
# 등록 시 '검색' API 권한 필요
NAVER_CLIENT_ID=your_naver_client_id_here
NAVER_CLIENT_SECRET=your_naver_client_secret_here

# ===== 텔레그램 봇 =====
# BotFather에서 발급받은 봇 토큰
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# 리포트를 받을 텔레그램 채팅 ID (개인 또는 그룹)
# 개인 채팅 ID 확인: https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
